import tkinter as tk
from tkinter import messagebox
import random
import string
import pyperclip

# Generate Password Function
def generate_password():
    try:
        length = int(entry_length.get())

        if length < 4:
            messagebox.showerror("Error", "Password must be at least 4 characters long")
            return

        # Character sets
        lower = string.ascii_lowercase
        upper = string.ascii_uppercase
        digits = string.digits
        symbols = string.punctuation

        # Exclude characters
        exclude = entry_exclude.get()
        for ch in exclude:
            lower = lower.replace(ch, "")
            upper = upper.replace(ch, "")
            digits = digits.replace(ch, "")
            symbols = symbols.replace(ch, "")

        # Build pool
        char_pool = ""

        if var_lower.get():
            char_pool += lower
        if var_upper.get():
            char_pool += upper
        if var_digits.get():
            char_pool += digits
        if var_symbols.get():
            char_pool += symbols

        if not char_pool:
            messagebox.showerror("Error", "Select at least one character type")
            return

        password = []

        # Ensure security rules
        if var_lower.get():
            password.append(random.choice(lower))
        if var_upper.get():
            password.append(random.choice(upper))
        if var_digits.get():
            password.append(random.choice(digits))
        if var_symbols.get():
            password.append(random.choice(symbols))

        # Fill remaining
        while len(password) < length:
            password.append(random.choice(char_pool))

        random.shuffle(password)

        final_password = "".join(password)

        entry_result.delete(0, tk.END)
        entry_result.insert(0, final_password)

    except ValueError:
        messagebox.showerror("Error", "Enter a valid number")


# Copy to Clipboard
def copy_password():
    password = entry_result.get()
    if password:
        pyperclip.copy(password)
        messagebox.showinfo("Copied", "Password copied to clipboard!")
    else:
        messagebox.showwarning("Warning", "No password generated")


# GUI Setup
root = tk.Tk()
root.title("Advanced Password Generator")
root.geometry("420x450")
root.resizable(False, False)

# Title
tk.Label(root, text="🔐 Advanced Password Generator", font=("Arial", 16, "bold")).pack(pady=10)

# Length Input
tk.Label(root, text="Enter Password Length:").pack()
entry_length = tk.Entry(root)
entry_length.pack(pady=5)

# Options
var_lower = tk.IntVar(value=1)
var_upper = tk.IntVar(value=1)
var_digits = tk.IntVar(value=1)
var_symbols = tk.IntVar(value=1)

tk.Checkbutton(root, text="Include Lowercase (a-z)", variable=var_lower).pack(anchor='w', padx=20)
tk.Checkbutton(root, text="Include Uppercase (A-Z)", variable=var_upper).pack(anchor='w', padx=20)
tk.Checkbutton(root, text="Include Numbers (0-9)", variable=var_digits).pack(anchor='w', padx=20)
tk.Checkbutton(root, text="Include Symbols (!@#...)", variable=var_symbols).pack(anchor='w', padx=20)

# Exclude Characters
tk.Label(root, text="Exclude Characters (optional):").pack(pady=5)
entry_exclude = tk.Entry(root)
entry_exclude.pack()

# Generate Button
tk.Button(root, text="Generate Password", command=generate_password,
          bg="green", fg="white", width=20).pack(pady=15)

# Result
tk.Label(root, text="Generated Password:").pack()
entry_result = tk.Entry(root, width=30, font=("Arial", 12))
entry_result.pack(pady=5)

# Copy Button
tk.Button(root, text="Copy to Clipboard", command=copy_password,
          bg="blue", fg="white", width=20).pack(pady=10)

# Run App
root.mainloop()
